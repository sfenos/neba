section("15. HOF")
# ─────────────────────────────────────────────────────
check("map",          map([1,2,3],fn(x) x*2)[2],    6)
check("map range",    map(0..5,fn(x) x*x)[4],       16)
check("filter",       filter([1,2,3,4],fn(x) x%2==0)[0], 2)
check("filter range", len(filter(0..10,fn(x) x%2==0)), 5)
check("reduce sum",   reduce([1,2,3,4,5],fn(a,b) a+b), 15)
check("reduce init",  reduce([1,2,3],fn(a,b) a+b,10),  16)
check("reduce mul",   reduce([1,2,3,4,5],fn(a,b) a*b),  120)

fn pipeline()
    return reduce(
        map(
            filter([1,2,3,4,5,6],fn(x) x%2==0),
            fn(x) x*x
        ),
        fn(a,b) a+b
    )
check("pipeline",     pipeline(), 56)

fn is_pos(n)
    return n > 0
check("fn named hof", len(filter([-1,0,1,2],is_pos)), 2)

# ─────────────────────────────────────────────────────
section("16. Error handling")
# ─────────────────────────────────────────────────────
fn safe_div(a, b)
    if b == 0
        return Err("division by zero")
    return Ok(a / b)

let ok_r = safe_div(10, 2)
let err_r = safe_div(5, 0)

check("is_ok",        ok_r.is_ok(),         true)
check("is_err ok",    ok_r.is_err(),        false)
check("unwrap",       ok_r.unwrap(),        5.0)
check("unwrap_or ok", ok_r.unwrap_or(0.0), 5.0)
check("is_err",       err_r.is_err(),       true)
check("is_ok err",    err_r.is_ok(),        false)
check("unwrap_or err",err_r.unwrap_or(0.0), 0.0)
check("unwrap_err",   err_r.unwrap_err(),   "division by zero")
check("value ok",     ok_r.value(),         5.0)

let s1 = Some(42)
let n1 = None
check("is_some",      s1.is_some(),         true)
check("is_none some", s1.is_none(),         false)
check("is_none",      n1.is_none(),         true)
check("unwrap some",  s1.unwrap(),          42)
check("unwrap_or s",  s1.unwrap_or(0),      42)
check("unwrap_or n",  n1.unwrap_or(99),     99)
check("value some",   s1.value(),           42)

fn match_result(r)
    match r
        Ok(v)  => return v
        Err(e) => return "error: " + e
check("match ok",     match_result(Ok(42)),        42)
check("match err",    match_result(Err("boom")),   "error: boom")

fn match_option(o)
    match o
        Some(v) => return v * 2
        None    => return -1
check("match some",   match_option(Some(5)), 10)
check("match none",   match_option(None),    -1)

