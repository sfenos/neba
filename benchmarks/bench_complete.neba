# ─────────────────────────────────────────────────────

fn dict_insert_10k()
    var d = {}
    var i = 0
    while i < 10000
        d[str(i)] = i
        i += 1
    return len(d)
bench_once("dict insert 10K",     dict_insert_10k)

fn dict_lookup_10k()
    var d = {}
    var i = 0
    while i < 10000
        d[str(i)] = i
        i += 1
    var s = 0
    var j = 0
    while j < 10000
        s += d[str(j)]
        j += 1
    return s
bench_once("dict insert+lookup 10K", dict_lookup_10k)

fn dict_iter_10k()
    var d = {}
    var i = 0
    while i < 10000
        d[str(i)] = i
        i += 1
    var s = 0
    for k in keys(d)
        s += d[k]
    return s
bench_once("dict iter 10K",       dict_iter_10k)

