# ═══════════════════════════════════════════════════════════════════════════════
# Neba — Test Suite Completo v0.2.32+
# Copre: tipi, operatori, stringhe, array, dict, classi, traits, closures,
#        pattern matching, error handling, HOF, TypedArray, NdArray, stdlib
# ═══════════════════════════════════════════════════════════════════════════════

var passed = 0
var failed = 0
var section_passed = 0
var section_failed = 0
var current_section = ""

fn check(label, got, exp)
    if got == exp
        passed += 1
        section_passed += 1
    else
        failed += 1
        section_failed += 1
        println(f"  ✗ FAIL [{label}]: got={got}  exp={exp}")

fn check_near(label, got, exp)
    var diff = got - exp
    if diff < 0.0
        diff = -diff
    if diff < 0.0001
        passed += 1
        section_passed += 1
    else
        failed += 1
        section_failed += 1
        println(f"  ✗ FAIL [{label}]: got={got}  exp={exp}")

fn section(name)
    if current_section != ""
        if section_failed == 0
            println(f"  ✓ {current_section} ({section_passed} tests)")
        else
            println(f"  ✗ {current_section} ({section_passed} ok, {section_failed} FAIL)")
    current_section = name
    section_passed = 0
    section_failed = 0

fn end_section()
    section("")

