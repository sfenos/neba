check_approx("math.ceil",      math.ceil(3.2),    4.0)
check_approx("math.abs(-2)",   math.abs(-2.0),    2.0)
check_approx("math.sinh(0)",   math.sinh(0.0),    0.0)
check_approx("math.cosh(0)",   math.cosh(0.0),    1.0)
