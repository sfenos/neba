fn hof_map_100k()
    return sum(map(0..100000, fn(x) x * 2))
bench_once("map 100K",            hof_map_100k)

fn hof_filter_100k()
    return len(filter(0..100000, fn(x) x % 2 == 0))
bench_once("filter 100K",         hof_filter_100k)

fn hof_reduce_100k()
    return reduce(map(0..10000, fn(x) x), fn(a,b) a+b)
bench_once("reduce 10K",          hof_reduce_100k)

fn hof_pipeline()
    return reduce(
        map(filter(0..50000, fn(x) x % 3 == 0), fn(x) x * x),
        fn(a,b) a+b
    )
bench_once("filter→map→reduce 50K", hof_pipeline)

