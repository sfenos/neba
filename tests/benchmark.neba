# ─────────────────────────────────────────────────────────────
# 15. BENCHMARK DI SISTEMA — ALGORITMI CLASSICI
# ─────────────────────────────────────────────────────────────
println("━━━ 15. Algoritmi classici ━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn sieve_of_eratosthenes(n)
    var is_prime = []
    for i in 0..n
        push(is_prime, true)
    is_prime[0] = false
    if n > 1
        is_prime[1] = false
    var i = 2
    while i * i < n
        if is_prime[i]
            var j = i * i
            while j < n
                is_prime[j] = false
                j += i
        i += 1
    var count = 0
    for p in is_prime
        if p
            count += 1
    return count

fn mergesort(arr)
    let n = len(arr)
    if n <= 1
        return arr
    let mid = n // 2
    let left  = mergesort(slice(arr, 0, mid))
    let right = mergesort(slice(arr, mid, n))
    var result = []
    var i = 0
    var j = 0
    while i < len(left) and j < len(right)
        if left[i] <= right[j]
            push(result, left[i])
            i += 1
        else
            push(result, right[j])
            j += 1
    while i < len(left)
        push(result, left[i])
        i += 1
    while j < len(right)
        push(result, right[j])
        j += 1
    return result

fn binary_search(arr, target)
    var lo = 0
    var hi = len(arr) - 1
    while lo <= hi
        let mid = (lo + hi) // 2
        if arr[mid] == target
            return mid
        elif arr[mid] < target
            lo = mid + 1
        else
            hi = mid - 1
    return -1

fn run_mergesort()
    let data = []
    var i = 999
    while i >= 0
        push(data, i)
        i -= 1
    let sorted_data = mergesort(data)
    return sorted_data[500]

fn run_binary_search()
    let data = range(100000)
    var found = 0
    for target in [1234, 56789, 99999, 42, 77777]
        let idx = binary_search(data, target)
        if idx >= 0
            found += 1
    return found

bench_once("sieve primes < 100K", fn() sieve_of_eratosthenes(100000))
bench_once("mergesort 1K elementi", fn() run_mergesort())
bench_once("binary search 100K ×5", fn() run_binary_search())
println("")

