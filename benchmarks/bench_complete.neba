println("── 7. OOP — classi e traits ─────────────────────────────")
# ─────────────────────────────────────────────────────

class Vec2
    x: Float = 0.0
    y: Float = 0.0
    fn __init__(self, x, y)
        self.x = x
        self.y = y
    fn dot(self, other)
        return self.x * other.x + self.y * other.y
    fn length(self)
        return (self.x*self.x + self.y*self.y)**0.5
    fn add(self, other)
        return Vec2(self.x + other.x, self.y + other.y)

fn oop_create_100k()
    var s = 0.0
    var i = 0
    while i < 100000
        let v = Vec2(float(i), float(i+1))
        s += v.length()
        i += 1
    return s
bench_once("OOP create+method 100K", oop_create_100k)

fn oop_method_call_100k()
    let a = Vec2(3.0, 4.0)
    let b = Vec2(1.0, 2.0)
    var s = 0.0
    var i = 0
    while i < 100000
        s += a.dot(b)
        i += 1
    return s
bench_once("OOP method call 100K", oop_method_call_100k)

trait Measurable2
    fn area(self) -> Float

class Square
    side: Float = 1.0
    fn __init__(self, s)
        self.side = s

impl Measurable2 for Square
    fn area(self) -> Float
        return self.side * self.side

class Circle2
    r: Float = 1.0
    fn __init__(self, r)
        self.r = r

impl Measurable2 for Circle2
    fn area(self) -> Float
        return math.pi * self.r * self.r

fn trait_dispatch_100k()
    let sq = Square(5.0)
    let ci = Circle2(3.0)
    var s = 0.0
    var i = 0
    while i < 50000
        s += sq.area() + ci.area()
        i += 1
    return s
bench_once("trait dispatch 100K", trait_dispatch_100k)

