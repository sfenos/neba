section("7. Controllo di flusso")
# ─────────────────────────────────────────────────────
fn test_if(n)
    if n > 10
        return "grande"
    elif n > 5
        return "medio"
    else
        return "piccolo"
check("if >10",  test_if(15), "grande")
check("elif",    test_if(7),  "medio")
check("else",    test_if(3),  "piccolo")

# if come espressione
let desc = if x > 0
    "positivo"
else
    "non positivo"
check("if expr", desc, "positivo")

# match letterali
fn match_lit(n)
    match n
        1 => return "uno"
        2 => return "due"
        _ => return "altro"
check("match 1", match_lit(1), "uno")
check("match 2", match_lit(2), "due")
check("match _", match_lit(9), "altro")

# match range
fn match_range(n)
    match n
        1..=5  => return "piccolo"
        6..=10 => return "medio"
        _      => return "grande"
check("match range 1", match_range(3),  "piccolo")
check("match range 2", match_range(8),  "medio")
check("match range 3", match_range(99), "grande")

# match or-pattern
fn match_or(c)
    match c
        "a" | "e" | "i" | "o" | "u" => return "vocale"
        _ => return "consonante"
check("match or v", match_or("a"), "vocale")
check("match or c", match_or("b"), "consonante")

# match stringhe
fn match_str(s)
    match s
        "hello" => return "greeting"
        "bye"   => return "farewell"
        _       => return "unknown"
check("match str 1", match_str("hello"), "greeting")
check("match str 2", match_str("bye"),   "farewell")
check("match str 3", match_str("?"),     "unknown")

# match bool
fn match_bool(b)
    match b
        true  => return "yes"
        false => return "no"
check("match bool t", match_bool(true),  "yes")
check("match bool f", match_bool(false), "no")

# match come espressione
let label = match x
    42 => "answer"
    _  => "other"
check("match expr", label, "answer")

# ─────────────────────────────────────────────────────
section("8. Loop")
# ─────────────────────────────────────────────────────
fn sum_while(n)
    var s = 0
    var i = 0
    while i <= n
        s += i
        i += 1
    return s
check("while sum",  sum_while(10), 55)

fn sum_for_excl(n)
    var s = 0
    for i in 0..n
        s += i
    return s
check("for excl",   sum_for_excl(10), 45)

fn sum_for_incl(n)
    var s = 0
    for i in 0..=n
        s += i
    return s
check("for incl",   sum_for_incl(10), 55)

fn break_test()
    var r = 0
    for i in 0..100
        if i == 5
            break
        r = i
    return r
check("break",      break_test(), 4)

fn continue_test()
    var s = 0
    for i in 0..10
        if i % 2 != 0
            continue
        s += i
    return s
check("continue",   continue_test(), 20)

fn for_array()
    var s = 0
    for v in [1,2,3,4,5]
        s += v
    return s
check("for array",  for_array(), 15)

fn for_str()
    var s = ""
    for c in "abc"
        s = s + c + "-"
    return s
check("for str",    for_str(), "a-b-c-")

fn nested_loop()
    var s = 0
    for i in 0..3
        for j in 0..3
            s += i * 3 + j
    return s
check("nested loop",nested_loop(), 36)

# ─────────────────────────────────────────────────────
section("9. Funzioni")
# ─────────────────────────────────────────────────────
fn add(a, b)
    return a + b
check("fn basic",   add(3,4),   7)

fn factorial(n)
    if n <= 1
        return 1
    return n * factorial(n-1)
check("recursion",  factorial(10), 3628800)

fn fib(n)
    if n <= 1
        return n
    return fib(n-1) + fib(n-2)
check("fib 10",     fib(10), 55)

fn with_default(x, y = 10)
    return x + y
check("default arg 1", with_default(5),    15)
check("default arg 2", with_default(5, 3), 8)

fn multi_return(n)
    if n > 0
        return "pos"
    elif n < 0
        return "neg"
    else
        return "zero"
check("multi return 1", multi_return(5),  "pos")
check("multi return 2", multi_return(-3), "neg")
check("multi return 3", multi_return(0),  "zero")

fn higher(f, x)
    return f(x)
fn double(n)
    return n * 2
check("fn as arg",  higher(double, 7), 14)

