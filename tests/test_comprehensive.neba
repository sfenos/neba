var ok = 0
var fail = 0
fn check(label, got, exp)
    if got == exp
        ok += 1
    else
        fail += 1
        println(f"  FAIL [{label}]: got={got}  exp={exp}")

fn check_near(label, got, exp, tol)
    let diff = got - exp
    var abs_diff = diff
    if diff < 0.0
        abs_diff = -diff
    if abs_diff < tol
        ok += 1
    else
        fail += 1
        println(f"  FAIL [{label}]: got={got}  exp≈{exp} (tol={tol})")

println("=== Sezione 1: Tipi e Letterali ===")
check("int_lit", 42, 42)
check("neg_int", -7, -7)
check("float_lit", 3.14, 3.14)
check("bool_true", true, true)
check("bool_false", false, false)
check("none_val", None, None)
check("str_lit", "hello", "hello")
check("str_escape", "a\nb", "a\nb")
check("hex_lit", 0xFF, 255)
check("bin_lit", 0b1010, 10)
check("oct_lit", 0o17, 15)

println("=== Sezione 2: Operatori Aritmetici ===")
check("add_ii", 3 + 4, 7)
check("sub_ii", 10 - 3, 7)
check("mul_ii", 6 * 7, 42)
check("div_ii", 10.0 / 4.0, 2.5)
check("intdiv", 10 // 3, 3)
check("mod_ii", 10 % 3, 1)
check("pow_ii", 2 ** 10, 1024)
check("neg", -(5), -5)
check("float_add", 1.5 + 2.5, 4.0)
check("int_float_promo", 1 + 2.0, 3.0)
check("const_fold", 2 + 3 * 4, 14)

println("=== Sezione 3: Confronti e Logica ===")
check("lt", 1 < 2, true)
check("le", 2 <= 2, true)
check("gt", 3 > 2, true)
check("ge", 3 >= 3, true)
check("eq", 5 == 5, true)
check("ne", 5 != 6, true)
check("and_tt", true and true, true)
check("and_tf", true and false, false)
check("or_tf", true or false, true)
check("or_ff", false or false, false)
check("not_t", not true, false)
check("not_f", not false, true)
check("chained_cmp", 1 < 2, true)
check("eq_str", "abc" == "abc", true)
check("ne_str", "abc" != "xyz", true)

println("=== Sezione 4: Bitwise ===")
check("bit_and", 0b1100 & 0b1010, 8)
check("bit_or", 0b1100 | 0b0011, 15)
check("bit_xor", 0b1111 ^ 0b0101, 10)
check("bit_not", ~0, -1)
check("shl", 1 << 8, 256)
check("shr", 256 >> 4, 16)

println("=== Sezione 5: Variabili e Scope ===")
let x = 10
var y = 20
y += 5
check("let_immut", x, 10)
check("var_mut", y, 25)
var a = 0
a += 1
a -= 1
a *= 3
a += 10
check("compound_assign", a, 10)
# scope anidato
var outer = 0
fn scope_test()
    let inner = 42
    outer = 100
scope_test()
check("outer_scope_write", outer, 100)

println("=== Sezione 6: if/elif/else ===")
fn classify(n)
    if n < 0
        return "neg"
    elif n == 0
        return "zero"
    elif n < 10
        return "small"
    else
        return "large"
check("if_neg", classify(-1), "neg")
check("if_zero", classify(0), "zero")
check("if_small", classify(5), "small")
check("if_large", classify(100), "large")

println("=== Sezione 7: Loop ===")
var sum_w = 0
var i = 0
while i < 10
    sum_w += i
    i += 1
check("while_sum", sum_w, 45)

var sum_f = 0
for j in range(10)
    sum_f += j
check("for_range_sum", sum_f, 45)

var sum_r = 0
for k in range(1, 11)
    sum_r += k
check("for_range_1_11", sum_r, 55)

var sum_s = 0
for k in range(0, 100, 2)
    sum_s += k
check("for_range_step", sum_s, 2450)

var sum_arr = 0
for v in [10, 20, 30]
    sum_arr += v
check("for_in_array", sum_arr, 60)

var sum_str = 0
for ch in "abc"
    sum_str += ord(ch)
check("for_in_str", sum_str, 294)

# break e continue
var count_b = 0
for i in range(100)
    if i == 5
        break
    count_b += 1
check("break", count_b, 5)

var count_c = 0
for i in range(10)
    if i % 2 == 0
        continue
    count_c += 1
check("continue", count_c, 5)

println("=== Sezione 8: Funzioni ===")
fn add(a, b)
    return a + b
check("fn_basic", add(3, 4), 7)

fn factorial(n)
    if n <= 1
        return 1
    return n * factorial(n - 1)
check("fn_recursive", factorial(10), 3628800)

fn with_defaults(x, y=10, z=100)
    return x + y + z
check("fn_defaults_all", with_defaults(1, 2, 3), 6)
check("fn_defaults_partial", with_defaults(1, 2), 103)
check("fn_defaults_none", with_defaults(1), 111)

fn variadics_test()
    return 42
check("fn_call", variadics_test(), 42)

# closures
fn make_counter(start)
    var n = start
    fn inc()
        n += 1
        return n
    return inc
let c = make_counter(0)
c()
c()
check("closure_upvalue", c(), 3)

# higher-order
fn apply(f, x)
    return f(x)
check("hof_apply", apply(fn(x) => x * x, 5), 25)

println("=== Sezione 9: Lambda ===")
let double = fn(x) => x * 2
check("lambda_def", double(7), 14)
let add3 = fn(a, b, c) => a + b + c
check("lambda_multi", add3(1, 2, 3), 6)
check("lambda_inline", (fn(x) => x + 100)(42), 142)

