section("13. Array")
# ─────────────────────────────────────────────────────
var arr = [3, 1, 4, 1, 5, 9, 2, 6]
check("len",          len(arr),      8)
check("idx 0",        arr[0],        3)
check("idx neg",      arr[-1],       6)
check("contains t",   contains(arr,5), true)
check("contains f",   contains(arr,7), false)

push(arr, 99)
check("push",         arr[-1],       99)
check("pop",          pop(arr),      99)

insert(arr, 0, 100)
check("insert",       arr[0],        100)
remove(arr, 100)
check("remove",       arr[0],        3)

sort(arr)
check("sort 0",       arr[0],        1)
check("sort last",    arr[-1],       9)

reverse(arr)
check("reverse 0",    arr[0],        9)

check("join",         join([1,2,3],","), "1,2,3")
check("flatten",      flatten([[1,2],[3,4]])[2], 3)
check("unique",       len(unique([1,2,2,3,1])), 3)
check("concat",       concat([1,2],[3,4])[2],   3)
check("slice",        slice([1,2,3,4,5],1,4)[0], 2)
check("index arr",    index([10,20,30],20),      1)
check("index miss",   index([10,20,30],99),     -1)
check("count arr",    count([1,2,1,3],1),        2)
check("find",         find([10,20,30],fn(x) x>15), 20)
check("find none",    find([1,2,3],fn(x) x>100)==None, true)
check("find_index",   find_index([10,20,30],fn(x) x>15), 1)
check("find_idx miss",find_index([1,2,3],fn(x) x>100), -1)
check("sorted asc",   sorted([3,1,2])[0],        1)
check("sorted desc",  sorted([3,1,2],true)[0],   3)
check("sorted key",   sorted(["ba","a","ccc"],fn(s) len(s))[0], "a")
check("any t",        any([false,true,false]),    true)
check("any f",        any([false,false]),         false)
check("all t",        all([true,true]),           true)
check("all f",        all([true,false]),          false)
check("zip",          zip([1,2],[3,4])[0][1],    3)
check("zip3",         zip([1,2],[3,4],[5,6])[1][2], 6)
check("enumerate",    enumerate(["a","b"])[1][0], 1)
check("enum start",   enumerate(["a"],5)[0][0],  5)
check("range excl",   len(0..10),                10)
check("range incl",   len(0..=10),               11)

