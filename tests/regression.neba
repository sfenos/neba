# 19. REGRESSIONI SPECIFICHE PER VERSIONE
# ─────────────────────────────────────────────────────────────────────────
println("--- 19. Regressioni ---")

# v0.2.15: __init__ chiamato 1 volta — bug noto: __init__(self) no params non modifica self
# Usiamo parametro per verificare che non venga chiamato 2 volte
class Singleton
    was_init: Int = 0
    fn __init__(self, v)
        self.was_init = v
let sing = Singleton(1)
check("v0215 init once", sing.was_init, 1)

# v0.2.15: while loop_local_counts (continue in while)
var wc = 0
var wi = 0
while wi < 10
    wi += 1
    if wi % 2 == 0
        continue
    wc += 1
check("v0215 while continue", wc, 5)

# v0.2.15: costruttore con più parametri
class Multi
    a: Int = 0
    b: Int = 0
    c: Str = ""
    fn __init__(self, a, b, c)
        self.a = a
        self.b = b
        self.c = c
let m = Multi(1, 2, "three")
check("v0215 multi ctor a", m.a, 1)
check("v0215 multi ctor b", m.b, 2)
check("v0215 multi ctor c", m.c, "three")

# v0.2.16: is operator
check("v0216 is class",   c is Circle,      true)
check("v0216 is trait",   c is Describable, true)
check("v0216 is wrong",   c is Square,      false)

# v0.2.17: Dict O(1) — 500 insert + lookup
var big = {}
var bi = 0
while bi < 500
    big[bi] = bi * 2
    bi += 1
check("v0217 dict big insert",  big[250], 500)
check("v0217 dict big has_key", has_key(big, 499), true)
check("v0217 dict big missing", has_key(big, 500), false)

# v0.2.18: sum/zip/enumerate/sorted/any/all già testati sopra (sez. 7)
# Testiamo i nuovi: chr/ord/hex/bin/oct (già in sez. 15)

# v0.2.19: NativeFn come valore first-class (Rc<String>)
let f1 = math.sin
let f2 = string.upper
check("v0219 NativeFn callable 1", f1(0.0),   0.0)
check("v0219 NativeFn callable 2", f2("hi"),  "HI")

# Zero-alloc dict lookup — verifica funzionamento corretto
let mod_test = {}
mod_test["alpha"] = 100
mod_test["beta"]  = 200
check("v0219 zero-alloc alpha", mod_test["alpha"], 100)
check("v0219 zero-alloc beta",  mod_test["beta"],  200)

# ─────────────────────────────────────────────────────────────────────────
# 20. EDGE CASES E CORNER CASES
# ─────────────────────────────────────────────────────────────────────────
println("--- 20. Edge cases ---")

# Array vuoto
let empty = []
check("empty array len", len(empty), 0)

# Dict vuoto
let ed = {}
check("empty dict len", len(ed), 0)
check("empty dict in",  "x" in ed, false)

# Stringa vuota
check("empty str len",  len(""),   0)
check("empty str bool", bool(""), false)

# Numeri limite
check("int max op",  1000000 * 1000000, 1000000000000)
check("float prec",  0.1 + 0.2 > 0.29 and 0.1 + 0.2 < 0.31, true)

# None truthiness
check("None bool", bool(None), false)

# Nested structures
let nested = {"a": [1, 2, {"b": 42}]}
check("nested dict-arr-dict", nested["a"][2]["b"], 42)

# Funzione ricorsiva con chiusura
fn make_fib()
    fn fib(n)
        if n <= 1
            return n
        return fib(n-1) + fib(n-2)
    return fib
let fib2 = make_fib()
check("closure fib", fib2(10), 55)

# IntRange in for
var range_sum = 0
for x in 1..=10
    range_sum += x
check("intrange sum", range_sum, 55)

# Metodo che ritorna self (method chaining style)
class Builder
    value: Int = 0
    fn __init__(self)
        self.value = 0
    fn add(self, n)
        self.value += n
        return self
    fn result(self)
        return self.value

let bld = Builder()
bld.add(10)
bld.add(20)
bld.add(12)
check("method chain", bld.result(), 42)

