println("── 18. Stdlib ──")
ci("abs positivo",  abs(5),    5)
ci("abs negativo",  abs(-5),   5)
ci("abs zero",      abs(0),    0)
ci("min(3,7)",      min(3,7),  3)
ci("min(7,3)",      min(7,3),  3)
ci("max(3,7)",      max(3,7),  7)
ci("max(7,3)",      max(7,3),  7)
