section("14. Dict")
# ─────────────────────────────────────────────────────
var d = {"a": 1, "b": 2, "c": 3}
check("len",          len(d),           3)
check("get",          d["a"],           1)
d["d"] = 4
check("set",          d["d"],           4)
check("has_key t",    has_key(d,"a"),   true)
check("has_key f",    has_key(d,"z"),   false)
check("keys",         len(keys(d)),     4)
check("values",       len(values(d)),   4)
check("items",        items(d)[0][0],   "a")
del_key(d,"d")
check("del_key",      has_key(d,"d"),   false)
check("merge",        merge({"x":1},{"y":2})["x"], 1)
check("merge overr",  merge({"x":1},{"x":9})["x"], 9)
check("dict_get",     dict_get(d,"a",0),  1)
check("dict_get def", dict_get(d,"z",99), 99)

fn dict_iter()
    var s = 0
    for k in keys(d)
        s += d[k]
    return s
check("dict iter",    dict_iter(), 6)

