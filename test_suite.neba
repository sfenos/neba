# ═══════════════════════════════════════════════════════════════════════════════
# Neba — Suite di test completa (v0.2.8)
# Testa tutte le funzionalità implementate: tipi, operatori, controllo di flusso,
# funzioni, closures, classi, trait, array, TypedArray, match, stdlib.
# Esegui con:  neba test_suite.neba
# Tutti i test devono passare prima di procedere alla versione successiva.
# ═══════════════════════════════════════════════════════════════════════════════

var passed = 0
var failed = 0

fn ok(label: Str)
    passed += 1

fn fail(label: Str, got: Str, expected: Str)
    failed += 1
    println(f"  ❌ FAIL: {label}  got={got}  expected={expected}")

fn ci(label: Str, got: Int, exp: Int)
    if got == exp
        ok(label)
    else
        fail(label, str(got), str(exp))

fn cf(label: Str, got: Float, exp: Float)
    if got == exp
        ok(label)
    else
        fail(label, str(got), str(exp))

fn cs(label: Str, got: Str, exp: Str)
    if got == exp
        ok(label)
    else
        fail(label, got, exp)

fn cb(label: Str, got: Bool, exp: Bool)
    if got == exp
        ok(label)
    else
        fail(label, str(got), str(exp))


# ── 1. LETTERALI E TIPI BASE ──────────────────────────────────────────────────
println("── 1. Letterali e tipi ──")
ci("int positivo",   42,    42)
ci("int negativo",   -7,    -7)
ci("int zero",       0,     0)
cf("float",          3.14,  3.14)
cf("float negativo", -1.5,  -1.5)
cs("stringa",        "ciao","ciao")
cs("stringa vuota",  "",    "")
cb("bool true",      true,  true)
cb("bool false",     false, false)


