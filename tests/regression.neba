check("math.e approx",         math.e > 2.71,     true)
check("math.gcd",              math.gcd(12, 8),   4)
check("math.lcm",              math.lcm(4, 6),    12)
check("math.factorial(5)",     math.factorial(5), 120)
check("math.isnan",            math.isnan(math.nan), true)
check("math.isinf",            math.isinf(math.inf), true)

math.seed(42)
let rv = math.random()
check("math.random range",     rv >= 0.0 and rv < 1.0, true)
let ri = math.randint(1, 10)
