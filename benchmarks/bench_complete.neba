# Neba — Benchmark Suite Completo v0.2.33
# Misura: tempo di esecuzione, throughput, operazioni al secondo
# Copre: aritmetica, ricorsione, loop, OOP, HOF, array, dict, TypedArray, NdArray,
#        stringhe, closures, algoritmi classici
# ═══════════════════════════════════════════════════════════════════════════════

fn bench(label, f, iters)
    let t0 = clock()
    var i = 0
    while i < iters
        f()
        i += 1
    let elapsed = clock() - t0
    let ms = elapsed * 1000.0
    let ops_sec = float(iters) / elapsed
    let ns_iter = elapsed * 1e9 / float(iters)
    println(f"  {label}: {ms:.1f}ms total | {ns_iter:.0f}ns/iter | {ops_sec:.0f} ops/sec")

fn bench_once(label, f)
    let t0 = clock()
    let result = f()
    let ms = (clock() - t0) * 1000.0
    println(f"  {label}: {ms:.1f}ms → {result}")

println("═══════════════════════════════════════════════════════════")
