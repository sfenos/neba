# 9. TYPEDARRAY — CALCOLO NUMERICO
# ─────────────────────────────────────────────────────────────
println("━━━ 9. TypedArray — calcolo numerico ━━━━━━━━━━━━━━━━━")

fn typed_sum()
    let a = linspace(0.0, 1.0, 1000000)
    return sum(a)

fn typed_dot()
    let a = ones(100000)
    let b = fill(100000, 2.0)
    return dot(a, b)

fn typed_arith()
    let a = linspace(0.0, 1.0, 100000)
    let b = linspace(1.0, 2.0, 100000)
    let c = a + b
    let d = c * 2.0
    return sum(d)

fn typed_stats()
    let a = linspace(0.0, 100.0, 1000000)
    let s = sum(a)
    let m = mean(a)
    let mn = min_elem(a)
    let mx = max_elem(a)
    return s + m + mn + mx

bench_once("TypedArray sum 1M", fn() typed_sum())
bench_once("TypedArray dot 100K", fn() typed_dot())
bench_once("TypedArray arith 100K", fn() typed_arith())
bench_once("TypedArray stats 1M", fn() typed_stats())
println("")

# ─────────────────────────────────────────────────────────────
# 10. NDARRAY — ALGEBRA LINEARE
# ─────────────────────────────────────────────────────────────
println("━━━ 10. NdArray — algebra lineare ━━━━━━━━━━━━━━━━━━━━")

fn ndarray_matmul_100()
    let A = nd.reshape(nd.ones(10000), [100, 100])
    let B = nd.reshape(nd.ones(10000), [100, 100])
    let C = nd.matmul(A, B)
    return nd.sum(C)

fn ndarray_matmul_200()
    let A = nd.reshape(nd.ones(40000), [200, 200])
    let B = nd.reshape(nd.ones(40000), [200, 200])
    let C = nd.matmul(A, B)
    return nd.sum(C)

fn ndarray_reductions()
    let m = nd.reshape(nd.ones(100000), [1000, 100])
    let row_sum = nd.sum(m, 1)
    let col_mean = nd.mean(m, 0)
    return nd.sum(row_sum) + nd.sum(col_mean)

fn ndarray_boolean_mask()
    let a = nd.array(to_list(linspace(0.0, 99.0, 100)))
    var count = 0
    var i = 0
    while i < 1000
        let mask = nd.gt(a, 50.0)
        let filtered = nd.masked(a, mask)
        count += 1
        i += 1
    return count

fn ndarray_broadcast()
    let a = nd.reshape(nd.zeros(100), [100, 1])
    let b = nd.reshape(nd.ones(10000), [100, 100])
    var c = nd.zeros(1)
    var i = 0
    while i < 100
        c = nd.add(a, b)
        i += 1
    return nd.sum(c)

bench_once("matmul 100×100", fn() ndarray_matmul_100())
bench_once("matmul 200×200", fn() ndarray_matmul_200())
bench_once("reductions 1000×100", fn() ndarray_reductions())
bench_once("boolean mask 100K×1K", fn() ndarray_boolean_mask())
bench_once("broadcast 100×100 (100×)", fn() ndarray_broadcast())
println("")

# ─────────────────────────────────────────────────────────────
# 11. PATTERN MATCHING
# ─────────────────────────────────────────────────────────────
println("━━━ 11. Pattern matching ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn match_int()
    var s = 0
    for i in 0..100000
        let v = match i % 5
            0 => 1
            1 => 2
            2 => 3
            3 => 4
            _ => 5
        s += v
    return s

fn match_option()
    fn maybe(n)
        if n % 3 == 0
            return Some(n)
        return None
    var s = 0
    for i in 0..100000
        match maybe(i)
            Some(v) => s += v
            None    => s += 0
    return s

fn match_result()
    fn safe_div(a, b)
        if b == 0
            return Err("div0")
        return Ok(a // b)
    var s = 0
    for i in 0..100000
        match safe_div(i, i % 7 + 1)
            Ok(v)  => s += v
            Err(_) => s += 0
    return s

bench_once("match int 5 arms 100K", fn() match_int())
bench_once("match Option 100K", fn() match_option())
bench_once("match Result 100K", fn() match_result())
println("")

# ─────────────────────────────────────────────────────────────
# 12. ERROR HANDLING E PROPAGAZIONE
# ─────────────────────────────────────────────────────────────
println("━━━ 12. Error handling ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn error_chain()
    fn step1(n)
        if n < 0
            return Err("negativo")
        return Ok(n * 2)
    fn step2(n)
        if n > 1000
            return Err("troppo grande")
        return Ok(n + 1)
    fn pipeline(n)
        let r1 = step1(n)?
        let r2 = step2(r1)?
        return Ok(r2)
    var ok_count = 0
    var err_count = 0
    for i in 0..100000
        match pipeline(i % 600 - 100)
            Ok(_)  => ok_count += 1
            Err(_) => err_count += 1
    return ok_count

bench_once("error propagation ? 100K", fn() error_chain())
println("")

