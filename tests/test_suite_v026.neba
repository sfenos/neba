let mm = nd.matmul(a2d, b2d)
check("matmul_00", mm[0][0], 19.0)
check("matmul_11", mm[1][1], 50.0)
let rs = nd.reshape(a2d, [4])
check("reshape_0", rs[0], 1.0)
check("reshape_3", rs[3], 4.0)
check("nd_sum", nd.sum(a2d), 10.0)
check("nd_mean", nd.mean(a2d), 2.5)
check("nd_min", nd.min(a2d), 1.0)
