bench_once("array sum 100K",      array_sum_100k)

fn array_sort_10k()
    var arr = []
    var i = 9999
    while i >= 0
        push(arr, i)
        i -= 1
    sort(arr)
    return arr[0]
bench_once("array sort 10K",      array_sort_10k)

fn array_search_10k()
    var arr = []
    var i = 0
    while i < 10000
        push(arr, i)
        i += 1
    var found = 0
    var j = 0
    while j < 100
        found += index(arr, j * 99)
        j += 1
    return found
bench_once("array index search x100", array_search_10k)

