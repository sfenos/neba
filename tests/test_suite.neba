section("3. Confronto e logica")

check("eq int", 3 == 3, true)
check("neq int", 3 != 4, true)
check("lt", 3 < 4, true)
check("le", 4 <= 4, true)
check("gt", 5 > 3, true)
check("ge", 5 >= 5, true)
check("eq str", "ciao" == "ciao", true)
check("neq str", "a" != "b", true)
check("and tt", true and true, true)
check("and tf", true and false, false)
check("or ft", false or true, true)
check("or ff", false or false, false)
check("not true", not true, false)
check("not false", not false, true)
check("in array", 3 in [1,2,3], true)
check("not in array", 5 not in [1,2,3], true)
check("in str", "ia" in "ciao", true)
check("not in str", "xx" not in "ciao", true)
section_end()

