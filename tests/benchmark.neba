# 6. DICT
# ─────────────────────────────────────────────────────────────
println("━━━ 6. Dict ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn dict_build()
    var d = {}
    for i in 0..10000
        d[str(i)] = i * i
    return len(d)

fn dict_lookup()
    var d = {}
    for i in 0..10000
        d[str(i)] = i
    var s = 0
    for i in 0..10000
        s += d[str(i)]
    return s

fn dict_merge_ops()
    var d = {}
    for i in 0..1000
        let d2 = {str(i): i, str(i*2): i*2}
        d = merge(d, d2)
    return len(d)

bench_once("dict build 10K", fn() dict_build())
bench_once("dict lookup 10K", fn() dict_lookup())
bench_once("dict merge 1K", fn() dict_merge_ops())
println("")

# ─────────────────────────────────────────────────────────────
# 7. OOP — CLASSI E TRAITS
# ─────────────────────────────────────────────────────────────
println("━━━ 7. OOP — classi e traits ━━━━━━━━━━━━━━━━━━━━━━━━━")

class Vec2
    x: Float = 0.0
    y: Float = 0.0
    fn __init__(self, x, y)
        self.x = x
        self.y = y
    fn add(self, other)
        return Vec2(self.x + other.x, self.y + other.y)
    fn dot(self, other)
        return self.x * other.x + self.y * other.y
    fn length(self)
        return math.sqrt(self.x * self.x + self.y * self.y)
    fn scale(self, s)
        return Vec2(self.x * s, self.y * s)

trait Shape
    fn area(self) -> Float
    fn perimeter(self) -> Float
    fn describe(self)
        println(f"  Area={self.area():.4f} Perimeter={self.perimeter():.4f}")

class Circle
    r: Float = 1.0
    fn __init__(self, r)
        self.r = r

impl Shape for Circle
    fn area(self)
        return math.pi * self.r * self.r
    fn perimeter(self)
        return 2.0 * math.pi * self.r

class Rectangle
    w: Float = 1.0
    h: Float = 1.0
    fn __init__(self, w, h)
        self.w = w
        self.h = h

impl Shape for Rectangle
    fn area(self)
        return self.w * self.h
    fn perimeter(self)
        return 2.0 * (self.w + self.h)

fn oop_vec2_ops()
    var v = Vec2(1.0, 0.0)
    var i = 0
    while i < 100000
        v = v.add(Vec2(0.001, 0.001)).scale(0.9999)
        i += 1
    return v.length()

fn oop_dispatch()
    let shapes = []
    for i in 0..1000
        if i % 2 == 0
            push(shapes, Circle(float(i % 10 + 1)))
        else
            push(shapes, Rectangle(float(i % 10 + 1), float(i % 5 + 1)))
    var total = 0.0
    for s in shapes
        total += s.area()
    return total

fn oop_method_chain()
    var total = 0.0
    for i in 0..10000
        let v = Vec2(float(i), float(i+1))
        total += v.add(Vec2(1.0, 1.0)).scale(2.0).dot(Vec2(1.0, 0.0))
    return total

bench_once("Vec2 ops 100K", fn() oop_vec2_ops())
bench_once("trait dispatch 1K shapes", fn() oop_dispatch())
bench_once("method chaining 10K", fn() oop_method_chain())
println("")

# ─────────────────────────────────────────────────────────────
# 8. CLOSURES E HOF AVANZATI
# ─────────────────────────────────────────────────────────────
println("━━━ 8. Closures e HOF avanzati ━━━━━━━━━━━━━━━━━━━━━━━")

fn make_adder(n)
    return fn(x) x + n

fn make_multiplier(n)
    return fn(x) x * n

fn compose(f, g)
    return fn(x) f(g(x))

fn closure_bench()
    let add10 = make_adder(10)
    let mul3  = make_multiplier(3)
    let f     = compose(add10, mul3)
    var s = 0
    for i in 0..100000
        s += f(i)
    return s

fn closure_counter()
    fn make_counter(start)
        var c = start
        fn inc()
            c += 1
            return c
        return inc
    let cnt = make_counter(0)
    var last = 0
    for i in 0..100000
        last = cnt()
    return last

fn hof_nested()
    let data = range(1000)
    var result = 0
    for i in 0..100
        result += reduce(
            map(data, fn(x) x * 2),
            fn(acc, x) acc + x
        )
    return result

bench_once("closure compose 100K", fn() closure_bench())
bench_once("closure counter 100K", fn() closure_counter())
bench_once("HOF nested 100×1K", fn() hof_nested())
println("")

