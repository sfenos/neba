println("── 12. Algoritmi classici ───────────────────────────────")
# ─────────────────────────────────────────────────────

fn bench_quicksort()
    fn quicksort(arr)
        if len(arr) <= 1
            return arr
        let pivot = arr[len(arr)//2]
        let left  = filter(arr, fn(x) x < pivot)
        let mid   = filter(arr, fn(x) x == pivot)
        let right = filter(arr, fn(x) x > pivot)
        return concat(concat(quicksort(left), mid), quicksort(right))
    let arr = map(0..1000, fn(x) 999 - x)
    let s = quicksort(arr)
    return s[0]
bench_once("quicksort 1K",        bench_quicksort)

fn bench_primes_sieve()
    var sieve = map(0..10001, fn(x) true)
    sieve[0] = false
    sieve[1] = false
    var i = 2
    while i * i <= 10000
        if sieve[i]
            var j = i * i
            while j <= 10000
                sieve[j] = false
                j += i
        i += 1
    return len(filter(0..10001, fn(x) sieve[x]))
bench_once("sieve of eratosthenes 10K", bench_primes_sieve)

fn bench_matrix_mul_pure()
    fn matmul(a, b, n)
        var c = map(0..n, fn(i) map(0..n, fn(j) 0))
        var i = 0
        while i < n
            var j = 0
            while j < n
                var k = 0
                var s = 0
                while k < n
                    s += a[i][k] * b[k][j]
                    k += 1
                c[i][j] = s
                j += 1
            i += 1
        return c
    let n = 10
    let a = map(0..n, fn(i) map(0..n, fn(j) float(i*n+j+1)))
    let b = map(0..n, fn(i) map(0..n, fn(j) float(j*n+i+1)))
    let c = matmul(a, b, n)
    return c[0][0]
bench_once("matrix mul pure Neba 10×10", bench_matrix_mul_pure)

