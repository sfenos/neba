# ─────────────────────────────────────────────────────────────
# 1. RICORSIONE
# ─────────────────────────────────────────────────────────────
println("━━━ 1. Ricorsione ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn fib(n)
    if n <= 1
        return n
    return fib(n - 1) + fib(n - 2)

fn ackermann(m, n)
    if m == 0
        return n + 1
    if n == 0
        return ackermann(m - 1, 1)
    return ackermann(m - 1, ackermann(m, n - 1))

fn factorial(n)
    if n <= 1
        return 1
    return n * factorial(n - 1)

bench_once("fib(30)", fn() fib(30))
bench_once("fib(35)", fn() fib(35))
bench_once("ackermann(3,4)", fn() ackermann(3, 4))
bench_once("factorial(15)", fn() factorial(15))
println("")

# ─────────────────────────────────────────────────────────────
# 2. LOOP INTERI
# ─────────────────────────────────────────────────────────────
println("━━━ 2. Loop interi ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn loop_sum_1M()
    var s = 0
    var i = 0
    while i < 1000000
        s += i
        i += 1
    return s

fn loop_for_range()
    var s = 0
    for i in 0..1000000
        s += i
    return s

fn loop_nested()
    var s = 0
    for i in 0..1000
        for j in 0..1000
            s += i * j
    return s

fn loop_modulo()
    var count = 0
    for i in 0..1000000
        if i % 7 == 0
            count += 1
    return count

bench_once("while loop 1M sum", fn() loop_sum_1M())
bench_once("for-range 1M sum", fn() loop_for_range())
bench_once("nested loop 1000×1000", fn() loop_nested())
bench_once("modulo filter 1M", fn() loop_modulo())
println("")

# ─────────────────────────────────────────────────────────────
# 3. FLOATING POINT
# ─────────────────────────────────────────────────────────────
println("━━━ 3. Floating point ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn float_loop()
    var x = 1.0
    var i = 0
    while i < 1000000
        x = x * 1.0000001 + 0.000001
        i += 1
    return x

fn trig_loop()
    var s = 0.0
    var i = 0
    while i < 100000
        s += math.sin(float(i) * 0.0001) * math.cos(float(i) * 0.0002)
        i += 1
    return s

fn sqrt_loop()
    var s = 0.0
    for i in 1..100001
        s += math.sqrt(float(i))
    return s

fn pi_leibniz(n)
    var sum = 0.0
    for i in 0..n
        if i % 2 == 0
            sum += 1.0 / float(2 * i + 1)
        else
            sum -= 1.0 / float(2 * i + 1)
    return sum * 4.0

bench_once("float ops 1M", fn() float_loop())
bench_once("sin/cos 100K", fn() trig_loop())
bench_once("sqrt 100K", fn() sqrt_loop())
bench_once("pi leibniz 1M", fn() pi_leibniz(1000000))
println("")

