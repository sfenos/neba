section("=== 17. NDARRAY ===")
let m = zeros(3, 3)
check("nd_shape0", m.shape[0], 3)
check("nd_ndim", m.ndim, 2)
check("nd_size", m.size, 9)
let eye = nd.eye(3)
check("eye_diag", eye[0][0], 1.0)
check("eye_off", eye[0][1], 0.0)
let a2d = nd.array([[1.0,2.0],[3.0,4.0]])
let b2d = nd.array([[5.0,6.0],[7.0,8.0]])
let c2d = a2d + b2d
check("nd_add00", c2d[0][0], 6.0)
check("nd_add11", c2d[1][1], 12.0)
let s2d = a2d * 2.0
