section_end()

# ─────────────────────────────────────────────────────────────
# 6. CONTROLLO DI FLUSSO
# ─────────────────────────────────────────────────────────────
section("6. Controllo di flusso")

fn if_basic(x)
    if x > 10
        return "grande"
    elif x > 5
        return "medio"
    else
        return "piccolo"

check("if grande", if_basic(15), "grande")
check("if medio", if_basic(7), "medio")
check("if piccolo", if_basic(3), "piccolo")

# if come espressione
let label = if 5 > 3
    "maggiore"
else
    "minore"
check("if expr", label, "maggiore")

# while
fn while_test()
    var i = 0
    var s = 0
    while i < 10
        s += i
        i += 1
    return s
check("while", while_test(), 45)

# for range esclusivo
fn for_excl()
    var s = 0
    for i in 0..5
        s += i
    return s
check("for 0..5", for_excl(), 10)

# for range inclusivo
fn for_incl()
    var s = 0
    for i in 0..=5
        s += i
    return s
check("for 0..=5", for_incl(), 15)

# for array
fn for_array()
    var s = 0
    for x in [1,2,3,4,5]
        s += x
    return s
check("for array", for_array(), 15)

# for stringa
fn for_str()
    var count = 0
    for c in "hello"
        count += 1
    return count
check("for string", for_str(), 5)

# break
fn break_test()
    var i = 0
    while true
        if i >= 5
            break
        i += 1
    return i
check("break", break_test(), 5)

# continue
fn continue_test()
    var s = 0
    for i in 0..10
        if i % 2 != 0
            continue
        s += i
    return s
check("continue", continue_test(), 20)

section_end()

# ─────────────────────────────────────────────────────────────
# 7. FUNZIONI
# ─────────────────────────────────────────────────────────────
section("7. Funzioni")

fn somma(a, b)
    return a + b
check("fn basic", somma(3, 4), 7)

fn con_default(x, y = 10)
    return x + y
check("default arg usato", con_default(5), 15)
check("default arg override", con_default(5, 20), 25)

fn ricorsione(n)
    if n <= 0
        return 0
    return n + ricorsione(n - 1)
check("ricorsione", ricorsione(10), 55)

fn multi_return(x)
    if x > 0
        return "pos"
    elif x < 0
        return "neg"
    return "zero"
check("multi return pos", multi_return(5), "pos")
check("multi return neg", multi_return(-3), "neg")
check("multi return zero", multi_return(0), "zero")

fn fn_as_value(f, x)
    return f(x)
fn doppio(n)
    return n * 2
check("fn as value", fn_as_value(doppio, 7), 14)

section_end()

# ─────────────────────────────────────────────────────────────
# 8. LAMBDA E CLOSURES
# ─────────────────────────────────────────────────────────────
section("8. Lambda e closures")

let quadrato = fn(x) x * x
check("lambda basic", quadrato(5), 25)

let cubo = fn(x) => x * x * x
check("lambda arrow", cubo(3), 27)

# closure cattura variabile
let offset = 10
let add_offset = fn(x) x + offset
check("closure cattura", add_offset(5), 15)

# closure con stato (via classe o upvalue mutable)
fn make_counter(start)
    var c = start
    fn next()
        c += 1
        return c
    return next

let cnt = make_counter(0)
check("closure upvalue 1", cnt(), 1)
check("closure upvalue 2", cnt(), 2)
check("closure upvalue 3", cnt(), 3)

# closure indipendenti
let cnt2 = make_counter(100)
check("closure indipendente", cnt2(), 101)
check("cnt1 non influenzato", cnt(), 4)

# lambda passata direttamente
check("lambda inline map", map([1,2,3], fn(x) x*2), [2,4,6])
check("lambda inline filter", filter([1,2,3,4,5], fn(x) x > 3), [4,5])

section_end()

# ─────────────────────────────────────────────────────────────
# 9. CLASSI
# ─────────────────────────────────────────────────────────────
section("9. Classi")

class Punto
    x: Float = 0.0
    y: Float = 0.0
    fn __init__(self, x, y)
        self.x = x
        self.y = y
    fn distanza(self)
        return math.sqrt(self.x*self.x + self.y*self.y)
    fn __str__(self)
        return f"Punto({self.x}, {self.y})"
    fn trasla(self, dx, dy)
        self.x += dx
        self.y += dy
        return self

let p = Punto(3.0, 4.0)
check("classe init", p.x, 3.0)
check_approx("classe metodo", p.distanza(), 5.0, 0.0001)
check("classe str", str(p), "Punto(3.0, 4.0)")
check("is class", p is Punto, true)

# method chaining
p.trasla(1.0, 0.0)
check("method chain campo", p.x, 4.0)

# default fields
class Defaults
    a: Int = 42
    b: Str = "hello"
    fn __init__(self)
        pass

let d = Defaults()
check("default field int", d.a, 42)
check("default field str", d.b, "hello")

# field assignment
d.a = 99
check("field assign", d.a, 99)

section_end()

# ─────────────────────────────────────────────────────────────
# 10. TRAITS
# ─────────────────────────────────────────────────────────────
section("10. Traits")

trait Stampabile
    fn etichetta(self) -> Str

    fn stampa(self)
        println(f"  → {self.etichetta()}")

trait Misurabile
    fn misura(self) -> Float

class Rettangolo
    w: Float = 1.0
    h: Float = 1.0
    fn __init__(self, w, h)
        self.w = w
        self.h = h

impl Stampabile for Rettangolo
    fn etichetta(self)
        return f"Rettangolo {self.w}×{self.h}"

impl Misurabile for Rettangolo
    fn misura(self)
        return self.w * self.h

class Cerchio
    r: Float = 1.0
    fn __init__(self, r)
        self.r = r

impl Stampabile for Cerchio
    fn etichetta(self)
        return f"Cerchio r={self.r}"

impl Misurabile for Cerchio
    fn misura(self)
        return math.pi * self.r * self.r

let rect = Rettangolo(3.0, 4.0)
let circ = Cerchio(5.0)

check("trait method rect", rect.etichetta(), "Rettangolo 3.0×4.0")
check("trait method circ", circ.etichetta(), "Cerchio r=5.0")
check("trait measure rect", rect.misura(), 12.0)
check_approx("trait measure circ", circ.misura(), 78.53981633974483, 0.0001)
check("is trait rect", rect is Stampabile, true)
check("is trait circ", circ is Misurabile, true)
check("is class rect", rect is Rettangolo, true)

# default method
trait Greeting
    fn nome(self) -> Str
    fn saluta(self)
        return f"Ciao, sono {self.nome()}"

class Persona
    n: Str = ""
    fn __init__(self, n)
        self.n = n

impl Greeting for Persona
    fn nome(self)
        return self.n

let mario = Persona("Mario")
check("trait default method", mario.saluta(), "Ciao, sono Mario")

section_end()

