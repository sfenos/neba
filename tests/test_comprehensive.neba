println("=== Sezione 11: Stringhe ===")
let s = "Hello, World!"
check("str_len", len(s), 13)
check("str_idx", s[0], "H")
check("str_slice", s[0:5], "Hello")
check("str_upper", upper(s), "HELLO, WORLD!")
check("str_lower", lower("NEBA"), "neba")
check("str_strip", strip("  hi  "), "hi")
check("str_lstrip", lstrip("  hi  "), "hi  ")
check("str_rstrip", rstrip("  hi  "), "  hi")
check("str_split", split("a,b,c", ",")[1], "b")
check("str_join", join(["x", "y", "z"], "-"), "x-y-z")
