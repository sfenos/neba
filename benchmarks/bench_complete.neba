println("── 8. Closures ──────────────────────────────────────────")
# ─────────────────────────────────────────────────────

fn closure_counter_1m()
    fn make_counter()
        var c = 0
        fn inc()
            c += 1
            return c
        return inc
    let cnt = make_counter()
    var i = 0
    while i < 1000000
        cnt()
        i += 1
    return cnt()
bench_once("closure counter 1M", closure_counter_1m)

fn closure_capture_100k()
    var results = []
    var i = 0
    while i < 100
        let captured = i
        push(results, fn(x) x + captured)
        i += 1
    var s = 0
    for f in results
        s += f(10)
    return s
bench_once("closure capture x100", closure_capture_100k)

