section("23. Random")
# ─────────────────────────────────────────────────────
fn rand_in_range()
    let v = math.randint(0, 100)
    return v >= 0 and v <= 100
check("randint range",  rand_in_range(), true)

fn rand_float_range()
    let v = math.random()
    return v >= 0.0 and v < 1.0
check("random range",   rand_float_range(), true)

fn choice_valid()
    let v = random.choice([10,20,30,40])
    return v == 10 or v == 20 or v == 30 or v == 40
check("choice valid",   choice_valid(), true)

fn choice_global()
    let v = choice([1,2,3])
    return v >= 1 and v <= 3
check("choice global",  choice_global(), true)

fn shuffle_same_elems()
    var arr = [1,2,3,4,5]
    shuffle(arr)
    sort(arr)
    return arr[0] == 1 and arr[4] == 5
check("shuffle elems",  shuffle_same_elems(), true)

fn sample_valid()
    let s = sample([1,2,3,4,5], 3)
    return len(s) == 3
check("sample len",     sample_valid(), true)

# ─────────────────────────────────────────────────────
section("24. Algoritmi classici")
# ─────────────────────────────────────────────────────
fn quicksort(arr)
    if len(arr) <= 1
        return arr
    let pivot = arr[len(arr)//2]
    let left  = filter(arr, fn(x) x < pivot)
    let mid   = filter(arr, fn(x) x == pivot)
    let right = filter(arr, fn(x) x > pivot)
    return concat(concat(quicksort(left), mid), quicksort(right))

let unsorted = [3,6,8,10,1,2,1]
let qs = quicksort(unsorted)
check("quicksort 0",    qs[0], 1)
check("quicksort last", qs[-1],10)
check("quicksort len",  len(qs), 7)

fn binary_search(arr, target)
    var lo = 0
    var hi = len(arr) - 1
    while lo <= hi
        let mid = (lo + hi) // 2
        if arr[mid] == target
            return mid
        elif arr[mid] < target
            lo = mid + 1
        else
            hi = mid - 1
    return -1

let sorted_arr = [1,3,5,7,9,11,13,15]
check("bsearch found",  binary_search(sorted_arr, 7),  3)
check("bsearch first",  binary_search(sorted_arr, 1),  0)
check("bsearch last",   binary_search(sorted_arr, 15), 7)
check("bsearch miss",   binary_search(sorted_arr, 4), -1)

fn is_prime(n)
    if n < 2
        return false
    if n == 2
        return true
    if n % 2 == 0
        return false
    var i = 3
    while i * i <= n
        if n % i == 0
            return false
        i += 2
    return true

let primes = filter(2..50, is_prime)
check("primes len",     len(primes),   15)
check("primes first",   primes[0],      2)
check("primes last",    primes[-1],    47)

fn gcd_euclid(a, b)
    while b != 0
        var t = b
        b = a % b
        a = t
    return a
check("gcd 48 18",      gcd_euclid(48,18), 6)
check("gcd 100 75",     gcd_euclid(100,75), 25)

fn flatten_deep(arr)
    var result = []
    var i = 0
    while i < len(arr)
        let item = arr[i]
        if is_array(item)
            let sub = flatten_deep(item)
            var j = 0
            while j < len(sub)
                append(result, sub[j])
                j += 1
        else
            append(result, item)
        i += 1
    return result
let nested = [1,[2,[3,[4]]],5]
let flat = flatten_deep(nested)
check("flatten deep",   flat[2], 3)
check("flatten deep l", len(flat), 5)

