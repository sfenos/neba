# ═══════════════════════════════════════════════════════
# NEBA COMPREHENSIVE TEST SUITE v0.2.26
# 300+ test su tutte le funzionalità del linguaggio
# ═══════════════════════════════════════════════════════
var ok = 0
var fail = 0
var section_fail = 0

fn check(label, got, exp)
    if got == exp
        ok += 1
    else
        fail += 1
        section_fail += 1
        println(f"  FAIL [{label}]: got={got} exp={exp}")

fn section(name)
    if section_fail > 0
        println(f"  ↑ {section_fail} failure(s)")
    section_fail = 0
    println(name)

# ─── 1. TIPI PRIMITIVI ───────────────────────────────
section("=== 1. TIPI PRIMITIVI ===")
check("int_pos", 42, 42)
check("int_neg", -7, -7)
check("int_zero", 0, 0)
check("float", 3.14, 3.14)
check("float_neg", -2.5, -2.5)
check("bool_t", true, true)
check("bool_f", false, false)
check("none", None, None)
check("str_empty", "", "")
check("str_space", " ", " ")
check("str_unicode", "∑", "∑")
check("int_max", 9223372036854775807, 9223372036854775807)
check("type_int", type(1), "Int")
check("type_float", type(1.0), "Float")
check("type_bool", type(true), "Bool")
check("type_str", type("x"), "Str")
check("type_none", type(None), "None")

