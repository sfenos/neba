vx = 20
ci("var riassegna", vx, 20)

var vc = 0
vc += 3
vc -= 1
vc *= 4
ci("compound +=  -=  *=", vc, 8)

var vd = 10
vd /= 4
cf("compound /=", vd, 2.5)

var vm = 10
vm %= 3
ci("compound %=", vm, 1)


