# ── 19. INTERAZIONI TRA FEATURE ───────────────────────────────────────────────
println("── 19. Interazioni ──")

# closure + match
fn make_matcher(soglia: Int)
    fn classifica(n: Int) -> Str
        if n >= soglia
            return "alto"
        else
            return "basso"
    return classifica

let class10 = make_matcher(10)
cs("closure+match alto",  class10(15), "alto")
cs("closure+match basso", class10(5),  "basso")

# array + for + match
let valori = [1, 5, 12, 3, 8, 20]
var piccoli = 0
var grandi = 0
for v in valori
    let cat = match v
        1..=9 => "piccolo"
        _     => "grande"
    if cat == "piccolo"
        piccoli += 1
    else
        grandi += 1
ci("array+for+match piccoli", piccoli, 4)
ci("array+for+match grandi",  grandi,  2)

# ricorsione + match
fn segno(n: Int) -> Str
    if n == 0
        return "zero"
    elif n > 0
        return "pos"
    else
        return "neg"

cs("fn+match pos",  segno(5),  "pos")
cs("fn+match neg",  segno(-3), "neg")
cs("fn+match zero", segno(0),  "zero")

# classe + match
class Forma
    tipo: Str
    misura: Float

    fn __init__(self, t: Str, m: Float)
        self.tipo = t
        self.misura = m

    fn area(self) -> Float
        if self.tipo == "cerchio"
            return 3.14159 * self.misura ** 2
        elif self.tipo == "quadrato"
            return self.misura ** 2
        elif self.tipo == "triangolo"
            return 0.5 * self.misura ** 2
        else
            return 0.0

let fc = Forma("cerchio", 1.0)
let fq = Forma("quadrato", 4.0)
cf("classe+match cerchio",  fc.area(),  3.14159)
cf("classe+match quadrato", fq.area(),  16.0)


# ── 20. EDGE CASES ────────────────────────────────────────────────────────────
println("── 20. Edge cases ──")

# match con un solo arm wildcard
let ec1 = match 999
    _ => "sempre"
cs("match solo wildcard", ec1, "sempre")

# match con valore calcolato come subject
let ec2 = match 2 + 3
    5 => "cinque"
    _ => "altro"
cs("match subject calcolato", ec2, "cinque")

# while con counter che usa match
var wm_count = 0
var wm_i = 0
while wm_i < 6
    let skip = match wm_i
        1 | 3 | 5 => true
        _         => false
    if not skip
        wm_count += 1
    wm_i += 1
ci("while+match skip dispari", wm_count, 3)

# funzione che ritorna match su argomento
fn fizzbuzz(n: Int) -> Str
    if n % 15 == 0
        return "FizzBuzz"
    elif n % 3 == 0
        return "Fizz"
    elif n % 5 == 0
        return "Buzz"
    else
        return str(n)

cs("fizzbuzz 3",  fizzbuzz(3),  "Fizz")
cs("fizzbuzz 5",  fizzbuzz(5),  "Buzz")
cs("fizzbuzz 15", fizzbuzz(15), "FizzBuzz")
cs("fizzbuzz 7",  fizzbuzz(7),  "7")

# array popolato in loop con logica
var evens = []
for i in 0..10
    if i % 2 == 0
        push(evens, i)
ci("array push in loop len", len(evens), 5)
ci("array push in loop [0]", evens[0],   0)
ci("array push in loop [-1]",evens[-1],  8)

# chiusura che cattura array
fn make_accum()
    var acc = []
    fn add(v: Int)
        push(acc, v)
        return len(acc)
    return add

let accum = make_accum()
ci("closure+array add 1", accum(10), 1)
ci("closure+array add 2", accum(20), 2)
ci("closure+array add 3", accum(30), 3)


# ═══════════════════════════════════════════════════════════════════════════════
# RISULTATO FINALE
