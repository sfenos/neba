section("25. Edge cases")
# ─────────────────────────────────────────────────────
check("empty array",    len([]),           0)
check("empty dict",     len({}),           0)
check("empty str",      len(""),           0)
check("none eq",        None == None,      true)
check("none neq",       None != 0,         true)
check("neg mod",        -7 % 3,           -1)  # Rust semantics (remainder, not Python modulo)
check("float prec",     0.1 + 0.2 > 0.3,  true)
check("str eq",         "abc" == "abc",    true)
check("str neq",        "abc" != "ABC",    true)
check("arr eq",         [1,2,3] == [1,2,3], true)
check("arr neq",        [1,2,3] != [1,2,4], true)
check("deep nest fn",   (fn(x) (fn(y) x+y)(3))(5), 8)
check("range len 0",    len(5..5),         0)
check("range len incl", len(5..=5),        1)

fn tail_count(n)
    var i = 0
    var acc = 0
    while i < n
        acc += i
        i += 1
    return acc
check("large loop",     tail_count(10000), 49995000)

