fn int_loop_1m()
    var s = 0
    var i = 0
    while i < 1000000
        s += i
        i += 1
    return s
bench_once("int loop 1M add",     int_loop_1m)

fn int_arith()
    var s = 0
    var i = 0
    while i < 100000
        s += i * 3 - i // 2 + i % 7
        i += 1
    return s
bench_once("int arith 100K",      int_arith)

fn int_loop_10m()
    var s = 0
    var i = 0
    while i < 10000000
        s += i
        i += 1
    return s
bench_once("int loop 10M add",    int_loop_10m)

