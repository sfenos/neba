println("── 13. Pattern matching ─────────────────────────────────")
# ─────────────────────────────────────────────────────

fn bench_match_100k()
    fn classify(n)
        match n % 6
            0 => return "fizzbuzz"
            2 => return "fizz"
            3 => return "buzz"
            _ => return "none"
    var s = 0
    var i = 0
    while i < 100000
        let r = classify(i)
        s += len(r)
        i += 1
    return s
bench_once("match dispatch 100K", bench_match_100k)

fn bench_option_100k()
    fn safe_head(arr)
        if len(arr) > 0
            return Some(arr[0])
        return None
    var s = 0
    var i = 0
    while i < 100000
        let opt = safe_head([i, i+1, i+2])
        match opt
            Some(v) => s += v
            None    => s += 0
        i += 1
    return s
bench_once("option match 100K",   bench_option_100k)

# ─────────────────────────────────────────────────────
println("")
println("── 14. Error handling ───────────────────────────────────")
# ─────────────────────────────────────────────────────

fn bench_result_100k()
    fn safe_div(a, b)
        if b == 0
            return Err("zero")
        return Ok(a / b)
    var s = 0.0
    var i = 1
    while i <= 100000
        let r = safe_div(1000.0, float(i))
        if r.is_ok()
            s += r.unwrap()
        i += 1
    return s
bench_once("result handling 100K", bench_result_100k)

