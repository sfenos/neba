# ═══════════════════════════════════════════════════════════════════════════
# Neba — Regression test suite (v0.2.19)
# Copre TUTTE le funzionalità implementate fino ad oggi.
# Eseguire con: cargo run --release --bin neba -- tests/regression.neba
# Output atteso: "ALL N TESTS PASSED" (nessun FAIL)
# ═══════════════════════════════════════════════════════════════════════════

var ok = 0
var fail = 0

fn check(label, got, expected)
    if got == expected
        ok += 1
    else
        fail += 1
        println(f"FAIL [{label}]: got {got}, expected {expected}")

fn check_approx(label, got, expected)
    var diff = got - expected
    if diff < 0.0
        diff = -diff
    if diff < 0.0001
        ok += 1
    else
        fail += 1
        println(f"FAIL [{label}]: got {got}, expected ~{expected}")

fn check_true(label, cond)
    if cond
        ok += 1
    else
        fail += 1
        println(f"FAIL [{label}]: condition was false")


println("=== Neba Regression Suite v0.2.19 ===\n")

# ─────────────────────────────────────────────────────────────────────────
# 1. ARITMETICA E OPERATORI BASE
# ─────────────────────────────────────────────────────────────────────────
println("--- 1. Aritmetica ---")
check("int add",       1 + 2,        3)
check("int sub",       10 - 3,       7)
check("int mul",       4 * 5,        20)
check("int floordiv",  10 // 3,      3)
check("int mod",       10 % 3,       1)
check("int pow",       2 ** 10,      1024)
check("float div",     10 / 4,       2.5)
check("float add",     1.5 + 2.5,    4.0)
check("mixed add",     1 + 2.5,      3.5)
check("neg",           -(-5),        5)
check("str concat",    "ab" + "cd",  "abcd")
check("str repeat",    "ha" * 3,     "hahaha")
var _cmp1 = 10
_cmp1 += 5
check("compound +=",   _cmp1, 15)
var _cmp2 = 3
_cmp2 *= 4
check("compound *=",   _cmp2, 12)

# ─────────────────────────────────────────────────────────────────────────
# 2. CONFRONTO E LOGICA
# ─────────────────────────────────────────────────────────────────────────
println("--- 2. Confronto/logica ---")
check("eq true",   1 == 1,          true)
check("eq false",  1 == 2,          false)
check("ne",        1 != 2,          true)
check("lt",        1 < 2,           true)
check("gt",        2 > 1,           true)
check("le",        2 <= 2,          true)
check("ge",        3 >= 3,          true)
check("and",       true and false,  false)
check("or",        false or true,   true)
check("not",       not true,        false)
check("int==float",2 == 2.0,        true)

# ─────────────────────────────────────────────────────────────────────────
# 3. VARIABILI — let / var / scope
# ─────────────────────────────────────────────────────────────────────────
println("--- 3. Variabili ---")
let immutable = 42
check("let read", immutable, 42)

var mutable = 1
mutable = 99
check("var reassign", mutable, 99)

fn scope_test()
    let x = 10
    var y = 20
    y += x
    return y
check("scope fn", scope_test(), 30)

# ─────────────────────────────────────────────────────────────────────────
# 4. CONTROLLO DI FLUSSO — if/elif/else, while, for, break, continue
# ─────────────────────────────────────────────────────────────────────────
println("--- 4. Controllo di flusso ---")

# if/elif/else
fn classify(n)
    if n < 0
        return "negative"
    elif n == 0
        return "zero"
    else
        return "positive"
check("if neg",  classify(-1), "negative")
check("if zero", classify(0),  "zero")
check("if pos",  classify(1),  "positive")

# while
var w = 0
var i = 0
while i < 5
    w += i
    i += 1
check("while sum", w, 10)

# for range
var s = 0
for j in 0..5
    s += j
check("for range", s, 10)

# for inclusive range
var s2 = 0
for j in 0..=5
    s2 += j
check("for incl range", s2, 15)

# break
var bk = 0
for j in 0..100
    if j == 5
        break
    bk += 1
check("break", bk, 5)

# continue
var ct = 0
for j in 0..10
    if j % 2 == 0
        continue
    ct += 1
check("continue", ct, 5)

# for su array
var sa = 0
for x in [1, 2, 3, 4, 5]
    sa += x
check("for array", sa, 15)

# for su stringa
var chars = ""
for c in "hello"
    chars += c
check("for str", chars, "hello")

# nested break
var nb = 0
for a in 0..3
    for b in 0..3
        if b == 1
            break
        nb += 1
check("nested break", nb, 3)

# ─────────────────────────────────────────────────────────────────────────
# 5. FUNZIONI — parametri, return, default args, ricorsione, HOF
# ─────────────────────────────────────────────────────────────────────────
println("--- 5. Funzioni ---")

fn add(a, b)
    return a + b
check("fn basic", add(3, 4), 7)

fn greet(name, greeting="Hello")
    return f"{greeting}, {name}!"
check("default arg", greet("World"), "Hello, World!")
check("override arg", greet("World", "Hi"), "Hi, World!")

fn fib(n)
    if n <= 1
        return n
    return fib(n-1) + fib(n-2)
check("fib(10)", fib(10), 55)
check("fib(15)", fib(15), 610)

# funzione come valore
fn apply(f, x)
    return f(x)
fn double(x)
    return x * 2
check("HOF apply", apply(double, 5), 10)

# map/filter/reduce
let nums = [1, 2, 3, 4, 5]
fn _dbl(x)
    return x * 2
let doubled = map(nums, _dbl)
check("map", doubled[2], 6)

fn _even(x)
    return x % 2 == 0
let evens = filter(nums, _even)
check("filter len", len(evens), 2)
check("filter val", evens[0], 2)

fn _add2(acc, x)
    return acc + x
let total = reduce(nums, _add2, 0)
check("reduce", total, 15)

# ─────────────────────────────────────────────────────────────────────────
# 6. CLOSURE E UPVALUE
# ─────────────────────────────────────────────────────────────────────────
println("--- 6. Closure ---")

fn make_counter(start)
    var count = start
    fn increment()
        count += 1
        return count
    return increment

let c1 = make_counter(0)
let c2 = make_counter(10)
check("closure c1 step1", c1(), 1)
check("closure c1 step2", c1(), 2)
check("closure c2 independent", c2(), 11)
check("closure c1 step3", c1(), 3)

fn make_adder(n)
    fn _inner(x)
        return x + n
    return _inner
let add5 = make_adder(5)
check("closure adder", add5(10), 15)

# upvalue mutabile
fn accumulator()
    var total = 0
    fn add(x)
        total += x
        return total
    return add
let acc = accumulator()
check("upvalue acc 1", acc(10), 10)
check("upvalue acc 2", acc(20), 30)
check("upvalue acc 3", acc(5),  35)

