println("")
println("═══════════════════════════════════════")
if failed == 0
    println(f"✅  TUTTI I TEST PASSANO: {passed}/{passed}")
else
    println(f"❌  {failed} FALLIMENTI su {passed + failed} test")
    println("   Correggere prima di procedere alla versione successiva.")
println("═══════════════════════════════════════")
