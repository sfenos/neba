# ─────────────────────────────────────────────────────────────
# 5. ARRAY E COLLEZIONI
# ─────────────────────────────────────────────────────────────
println("━━━ 5. Array e collezioni ━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn array_build()
    var a = []
    for i in 0..100000
        push(a, i)
    return len(a)

fn array_sort()
    let a = range(10000)
    var r = sorted(a, true)
    return r[0]

fn array_hof_pipeline()
    let data = range(10000)
    let result = reduce(
        map(
            filter(data, fn(x) x % 2 == 0),
            fn(x) x * x
        ),
        fn(acc, x) acc + x
    )
    return result

fn array_zip_enumerate()
    let a = range(10000)
    let b = range(10000)
    let z = zip(a, b)
    let e = enumerate(z, 1)
    return len(e)

fn array_find()
    let a = range(100000)
    let r = find(a, fn(x) x > 99990)
    return r

fn array_sorted_key()
    let words = ["banana", "apple", "cherry", "date", "elderberry", "fig", "grape"]
    var result = []
    var i = 0
    while i < 1000
        result = sorted(words, fn(s) len(s))
        i += 1
    return result[0]

bench_once("array build 100K push", fn() array_build())
bench_once("sorted reverse 10K", fn() array_sort())
bench_once("HOF pipeline (filter+map+reduce) 10K", fn() array_hof_pipeline())
bench_once("zip+enumerate 10K", fn() array_zip_enumerate())
bench_once("find in 100K", fn() array_find())
bench_once("sorted key 1K×7", fn() array_sorted_key())
println("")

