# ─────────────────────────────────────────────────────────────────────────
# 10. CLASSI E OOP
# ─────────────────────────────────────────────────────────────────────────
println("--- 10. Classi ---")

class Point
    x: Float = 0.0
    y: Float = 0.0
    fn __init__(self, x, y)
        self.x = x
        self.y = y
    fn dist(self)
        return math.sqrt(self.x**2 + self.y**2)
    fn __str__(self)
        return f"Point({self.x}, {self.y})"

let p = Point(3.0, 4.0)
check("class field x",  p.x,      3.0)
check("class method",   p.dist(),  5.0)
# __str__ non ancora dispatchato da str() — limitazione v0.2.x
check("class exists",   p.x,       3.0)

# Nota: __init__ non può modificare globali direttamente (limitazione compilatore)
# ereditarietà
class Point3D
    x: Float = 0.0
    y: Float = 0.0
    z: Float = 0.0
    fn __init__(self, x, y, z)
        self.x = x
        self.y = y
        self.z = z
    fn dist(self)
        return math.sqrt(self.x**2 + self.y**2 + self.z**2)

let p3 = Point3D(1.0, 2.0, 2.0)
check("subclass dist", p3.dist(), 3.0)

# __init__ chiamato 1 volta: verifica via parametro (bug: __init__ no-params non modifica self)
class Counter
    calls: Int = 0
    fn __init__(self, v)
        self.calls = v
let cnt = Counter(1)
check("__init__ once", cnt.calls, 1)

# costruttore con parametri (regressione v0.2.15)
class Box
    value: Int = 0
    fn __init__(self, v)
        self.value = v
let b = Box(42)
check("ctor params", b.value, 42)

# ─────────────────────────────────────────────────────────────────────────
# 11. TRAITS — definizione, impl, dispatch, is (v0.2.16)
# ─────────────────────────────────────────────────────────────────────────
println("--- 11. Traits ---")

trait Describable
    fn describe(self) -> Str
        return "no description"

trait Resizable
    fn resize(self, factor)
        pass

class Circle
    radius: Float = 1.0
    fn __init__(self, r)
        self.radius = r

impl Describable for Circle
    fn describe(self)
        return f"Circle(r={self.radius})"

impl Resizable for Circle
    fn resize(self, factor)
        self.radius = self.radius * factor

class Square
    side: Float = 1.0
    fn __init__(self, s)
        self.side = s

impl Describable for Square
    fn describe(self)
        return f"Square(s={self.side})"

let c = Circle(5.0)
let sq = Square(3.0)

check("trait method circle",  c.describe(),  "Circle(r=5.0)")
check("trait method square",  sq.describe(), "Square(s=3.0)")
c.resize(2.0)
check("trait resize",         c.radius,      10.0)

# operatore is
check("is ClassName Circle",  c is Circle,         true)
check("is ClassName Square",  sq is Square,        true)
check("is wrong class",       c is Square,         false)
check("is Trait Describable", c is Describable,    true)
check("is Trait Resizable",   c is Resizable,      true)
check("is Trait not impl",    sq is Resizable,     false)

# default method
class Widget
    fn __init__(self)
        pass

impl Describable for Widget

let w = Widget()
check("default trait method", w.describe(), "no description")

# polimorfismo
fn describe_all(items)
    var result = ""
    for item in items
        result += item.describe() + ";"
    return result

check("polymorphism", describe_all([c, sq]), "Circle(r=10.0);Square(s=3.0);")

# ─────────────────────────────────────────────────────────────────────────
# 12. OPTION / RESULT
# ─────────────────────────────────────────────────────────────────────────
println("--- 12. Option/Result ---")

fn safe_div(a, b)
    if b == 0
        return None
    return Some(a / b)

let r1 = safe_div(10, 2)
let r2 = safe_div(10, 0)
check("Some value", r1 == Some(5.0), true)
check("None value", r2,              None)

fn parse_int(s)
    let n = string.to_int(s)
    return Ok(n)

let ok_val = parse_int("42")
check("Ok value", ok_val == Ok(42), true)

# match su Option/Result
fn unwrap_or(v, default)
    match v
        Some(x) => return x
        None    => return default
        Ok(x)   => return x
        Err(_)  => return default

check("match Some",  unwrap_or(Some(7), 0),   7)
check("match None",  unwrap_or(None, 99),     99)
check("match Ok",    unwrap_or(Ok(42), 0),    42)

# ─────────────────────────────────────────────────────────────────────────
# 13. MATCH EXPRESSION
# ─────────────────────────────────────────────────────────────────────────
println("--- 13. Match ---")

fn day_name(n)
    match n
        1 => return "Mon"
        2 => return "Tue"
        3 => return "Wed"
        _ => return "Other"

check("match 1", day_name(1), "Mon")
check("match 3", day_name(3), "Wed")
check("match _", day_name(9), "Other")

fn type_check(v)
    match v
        true  => return "bool_true"
        false => return "bool_false"
        0     => return "zero"
        _     => return "other"

check("match true",  type_check(true),  "bool_true")
check("match false", type_check(false), "bool_false")
check("match zero",  type_check(0),     "zero")
check("match other", type_check(42),    "other")

