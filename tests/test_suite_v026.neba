check("none_eq", None==None, true)

# ─── 4. LOGICA ────────────────────────────────────────
section("=== 4. LOGICA ===")
check("and_tt", true and true, true)
check("and_tf", true and false, false)
check("and_ff", false and false, false)
check("or_tt", true or false, true)
check("or_ff", false or false, false)
check("not_t", not true, false)
check("not_f", not false, true)
check("short_and", false and (1/0 > 0), false)  # short circuit
check("short_or", true or (1/0 > 0), true)

# ─── 5. STRINGHE ─────────────────────────────────────
section("=== 5. STRINGHE ===")
let s = "Hello, World!"
check("len", len(s), 13)
check("idx", s[0], "H")
check("neg_idx", s[-1], "!")
check("slice_start", s[0:5], "Hello")
check("slice_end", s[7:], "World!")
check("slice_neg", s[-6:], "World!")
check("concat", "foo"+"bar", "foobar")
check("repeat", "ab"*3, "ababab")
check("fstr_int", f"{42}", "42")
check("fstr_float", f"{3.14}", "3.14")
check("fstr_expr", f"{2+3}", "5")
check("upper", string.upper("hello"), "HELLO")
check("lower", string.lower("HELLO"), "hello")
check("strip", string.strip("  hi  "), "hi")
check("lstrip", string.lstrip("  hi  "), "hi  ")
check("rstrip", string.rstrip("  hi  "), "  hi")
check("replace", string.replace("aaa","a","b"), "bbb")
check("split2", len(string.split("a,b,c",",")), 3)
check("join", join(["a","b","c"],"-"), "a-b-c")
check("startswith", string.startswith("hello","hel"), true)
check("starts_with", string.starts_with("hello","hel"), true)
check("endswith", string.endswith("hello","llo"), true)
check("ends_with", string.ends_with("hello","llo"), true)
check("contains", string.contains("hello","ell"), true)
check("find", string.find("hello","ll"), 2)
check("count_s", string.count("aababc","ab"), 2)
check("zfill", string.zfill("42",5), "00042")
check("center", len(string.center("hi",10)), 10)
check("is_digit", string.is_digit("123"), true)
check("is_alpha", string.is_alpha("abc"), true)
check("is_alnum", string.is_alnum("abc123"), true)
check("capitalize", string.capitalize("hello world"), "Hello world")
check("title", string.title("hello world"), "Hello World")
check("str_int", str(42), "42")
check("str_float", str(3.14), "3.14")
check("str_bool", str(true), "true")

# ─── 6. ARRAY ─────────────────────────────────────────
section("=== 6. ARRAY ===")
let a = [10, 20, 30, 40, 50]
check("len_arr", len(a), 5)
check("idx_0", a[0], 10)
check("idx_last", a[4], 50)
check("idx_neg", a[-1], 50)
check("idx_neg2", a[-2], 40)
check("slice_arr", a[1:3], [20,30])
check("slice_from", a[3:], [40,50])
check("slice_to", a[:2], [10,20])
check("sum_arr", sum(a), 150)
check("min_arr", min(a), 10)
check("max_arr", max(a), 50)
let b = [3,1,4,1,5,9,2,6]
check("sorted_asc0", sorted(b)[0], 1)
check("sorted_asc_last", sorted(b)[-1], 9)
fn desc(x,y)
    return y - x
check("sorted_desc0", sorted(b, desc)[0], 9)
let c = [1,2,3]
push(c, 4)
check("push_len", len(c), 4)
check("push_val", c[3], 4)
let pv = pop(c)
check("pop_val", pv, 4)
check("pop_len", len(c), 3)
check("contains_t", contains(a, 30), true)
check("contains_f", contains(a, 99), false)
check("reverse", reverse([1,2,3]), [3,2,1])
check("any_t", any([false, true, false]), true)
check("any_f", any([false, false]), false)
check("all_t", all([true, true]), true)
check("all_f", all([true, false]), false)
let en = enumerate([10,20,30])
check("enum_i0", en[0][0], 0)
check("enum_v0", en[0][1], 10)
check("enum_i2", en[2][0], 2)
let z = zip([1,2,3],[4,5,6])
check("zip_0_0", z[0][0], 1)
check("zip_0_1", z[0][1], 4)
check("zip_len", len(z), 3)

