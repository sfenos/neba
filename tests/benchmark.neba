println("━━━ 14. Allocazione e GC pressure ━━━━━━━━━━━━━━━━━━━━")

fn alloc_many_arrays()
    var total = 0
    for i in 0..10000
        let a = [i, i+1, i+2, i+3, i+4]
        total += a[0] + a[4]
    return total

fn alloc_many_dicts()
    var total = 0
    for i in 0..10000
        let d = {"a": i, "b": i*2, "c": i*3}
        total += d["a"] + d["c"]
    return total

fn alloc_many_closures()
    var total = 0
    for i in 0..10000
        let f = make_adder(i)
        total += f(1)
    return total

fn alloc_many_instances()
    var total = 0.0
    for i in 0..10000
        let v = Vec2(float(i), float(i+1))
        total += v.length()
    return total

bench_once("alloc 10K arrays", fn() alloc_many_arrays())
bench_once("alloc 10K dicts", fn() alloc_many_dicts())
bench_once("alloc 10K closures", fn() alloc_many_closures())
bench_once("alloc 10K instances", fn() alloc_many_instances())
