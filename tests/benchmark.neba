# ============================================================
# Neba v0.2.33 — Benchmark Suite Completo
# ============================================================
# Misura: tempo (ms), throughput, confronto CPython reference
# Esegui con: ./target/release/neba tests/benchmark.neba
# ============================================================

fn bench(label, f, iterations)
    let t0 = clock()
    var i = 0
    while i < iterations
        f()
        i += 1
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    let per_iter = ms / float(iterations)
    println(f"  {label}: {ms:.1f}ms total  |  {per_iter:.4f}ms/iter  ({iterations} iter)")
    return ms

fn bench_once(label, f)
    let t0 = clock()
    let result = f()
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println(f"  {label}: {ms:.2f}ms  →  {result}")
    return ms

println("╔══════════════════════════════════════════════════════╗")
