println("━━━ 4. Stringhe ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

fn string_concat()
    var s = ""
    for i in 0..1000
        s = s + "x"
    return len(s)

fn string_fstring()
    var result = ""
    for i in 0..1000
        result = f"valore={i} quadrato={i*i}"
    return len(result)

fn string_ops()
    let s = "Hello, World! This is a test string for Neba."
    var count = 0
    for i in 0..10000
        let u = upper(s)
        let l = lower(s)
        let parts = string.split(s, " ")
        count += len(parts)
    return count

fn string_format_pos()
    var count = 0
    for i in 0..10000
        let r = string.format("{} + {} = {}", i, i+1, i+i+1)
        count += len(r)
    return count

bench_once("string concat 1K", fn() string_concat())
bench_once("f-string 1K", fn() string_fstring())
bench_once("string ops 10K", fn() string_ops())
bench_once("string.format positional 10K", fn() string_format_pos())
