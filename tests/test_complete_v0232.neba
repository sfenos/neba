section("10. Lambda e closures")
# ─────────────────────────────────────────────────────
let sq = fn(x) x * x
check("lambda",        sq(5),    25)

let sq2 = fn(x) => x * x
check("lambda arrow",  sq2(5),   25)

fn adder(n)
    return fn(x) x + n
let add5  = adder(5)
let add10 = adder(10)
check("closure 1",     add5(3),        8)
check("closure 2",     add10(3),       13)
check("closure indep", add5(add10(0)), 15)

fn compose(f, g)
    return fn(x) f(g(x))
let inc    = fn(x) x + 1
let dbl    = fn(x) x * 2
let dbl_inc = compose(inc, dbl)
check("compose",       dbl_inc(5),  11)

fn make_acc()
    var total = 0
    fn add(n)
        total += n
        return total
    return add
let acc = make_acc()
check("acc 1",         acc(10), 10)
check("acc 2",         acc(5),  15)
check("acc 3",         acc(3),  18)

let offset = 100
let shifted = map([1,2,3], fn(x) x + offset)
check("closure capture", shifted[0], 101)

# ─────────────────────────────────────────────────────
section("11. Classi")
# ─────────────────────────────────────────────────────
class Point
    x: Float = 0.0
    y: Float = 0.0
    fn __init__(self, x, y)
        self.x = x
        self.y = y
    fn dist(self)
        return (self.x**2 + self.y**2)**0.5
    fn __str__(self)
        return f"Point({self.x},{self.y})"
    fn translate(self, dx, dy)
        self.x += dx
        self.y += dy
        return self

let p = Point(3.0, 4.0)
check("class field x",  p.x,       3.0)
check("class field y",  p.y,       4.0)
check("class method",   p.dist(),  5.0)
check("class str",      str(p),    "Point(3.0,4.0)")
check("class is",       p is Point, true)

p.translate(1.0, 0.0)
check("class mutate",   p.x, 4.0)

let p2 = Point(0.0, 0.0).translate(3.0, 4.0)
check("method chain",   p2.dist(), 5.0)

class Counter
    value: Int = 0
    fn __init__(self, start = 0)
        self.value = start
    fn inc(self)
        self.value += 1
        return self
    fn dec(self)
        self.value -= 1
        return self
    fn get(self)
        return self.value

let cnt = Counter(10)
cnt.inc().inc().inc().dec()
check("counter chain", cnt.get(), 12)

class Stack
    items: Array = []
    fn __init__(self)
        self.items = []
    fn push(self, v)
        append(self.items, v)
    fn pop_top(self)
        if len(self.items) == 0
            return None
        let v = self.items[-1]
        pop(self.items)
        return v
    fn size(self)
        return len(self.items)
    fn is_empty(self)
        return len(self.items) == 0

let stk = Stack()
stk.push(1)
stk.push(2)
stk.push(3)
check("stack size",   stk.size(),    3)
check("stack pop",    stk.pop_top(), 3)
check("stack size2",  stk.size(),    2)
stk.pop_top()
stk.pop_top()
check("stack empty",  stk.is_empty(), true)
check("stack pop empty", stk.pop_top(), None)

# ─────────────────────────────────────────────────────
section("12. Traits")
# ─────────────────────────────────────────────────────
trait Describable
    fn describe(self) -> Str
    fn print_desc(self)
        return ">>> " + self.describe()

trait Measurable
    fn measure(self) -> Float
    fn is_big(self)
        return self.measure() > 10.0

class Circle
    r: Float = 1.0
    fn __init__(self, r)
        self.r = r

impl Describable for Circle
    fn describe(self) -> Str
        return f"Circle(r={self.r})"

impl Measurable for Circle
    fn measure(self) -> Float
        return math.pi * self.r * self.r

class Rect
    w: Float = 1.0
    h: Float = 1.0
    fn __init__(self, w, h)
        self.w = w
        self.h = h

impl Describable for Rect
    fn describe(self) -> Str
        return f"Rect({self.w}x{self.h})"

impl Measurable for Rect
    fn measure(self) -> Float
        return self.w * self.h

let ci = Circle(5.0)
let re = Rect(3.0, 4.0)

check("trait method",    ci.describe(),    "Circle(r=5.0)")
check("trait default",   ci.print_desc(),  ">>> Circle(r=5.0)")
check("trait measure c", math.abs(ci.measure() - 78.5398) < 0.01, true)
check("trait measure r", re.measure(),     12.0)
check("trait is_big c",  ci.is_big(),      true)
check("trait is_big r",  re.is_big(),      true)
check("is class c",      ci is Circle,     true)
check("is trait c",      ci is Describable, true)
check("is trait m",      ci is Measurable,  true)
check("is class r",      re is Rect,        true)

# abstract consecutivi
trait A
    fn method_a(self)
trait B
    fn method_b(self)
trait C
    fn method_c(self)
        return "default C"

class Multi
    fn __init__(self)
        pass

impl A for Multi
    fn method_a(self)
        return "a"
impl B for Multi
    fn method_b(self)
        return "b"
impl C for Multi

let m = Multi()
check("multi trait a",   m.method_a(), "a")
check("multi trait b",   m.method_b(), "b")
check("multi trait c",   m.method_c(), "default C")

