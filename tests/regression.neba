let sarr = [5, 3, 1, 4, 2]
math.shuffle(sarr)
check("math.shuffle len",      len(sarr), 5)
check("math.shuffle sum",      sum(sarr), 15)

let samp = math.sample([1,2,3,4,5], 3)
check("math.sample len",       len(samp), 3)

