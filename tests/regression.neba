println("--- 16. math module ---")

check_approx("math.sqrt(4)",   math.sqrt(4.0),    2.0)
check_approx("math.sin(0)",    math.sin(0.0),     0.0)
check_approx("math.cos(0)",    math.cos(1.0),     math.cos(1.0))
