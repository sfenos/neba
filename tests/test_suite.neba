# ============================================================
# Neba v0.2.33 — Test Suite Completo
# ============================================================
# Esegui con: ./target/release/neba tests/test_suite.neba
# ============================================================

var PASSED = 0
var FAILED = 0
var SECTION_FAILED = 0

fn check(label, got, exp)
    if got == exp
        PASSED += 1
    else
        FAILED += 1
        SECTION_FAILED += 1
        println(f"  ✗ FAIL [{label}]")
        println(f"      got: {got}")
        println(f"      exp: {exp}")

fn check_approx(label, got, exp, tol)
    let diff = abs(got - exp)
    if diff <= tol
        PASSED += 1
    else
        FAILED += 1
        SECTION_FAILED += 1
        println(f"  ✗ FAIL [{label}]: got={got}  exp={exp}  diff={diff}  tol={tol}")

fn section(name)
    SECTION_FAILED = 0
    println(f"\n━━━ {name} ━━━")

fn section_end()
    if SECTION_FAILED == 0
        println("  ✓ tutti i test passati")

println("╔══════════════════════════════════════════════════════╗")
println("║     Neba v0.2.33 — Test Suite Completo              ║")
println("╚══════════════════════════════════════════════════════╝")

# ─────────────────────────────────────────────────────────────
# 1. TIPI E LETTERALI
# ─────────────────────────────────────────────────────────────
section("1. Tipi e letterali")

check("int literal", 42, 42)
check("int negativo", -7, -7)
check("int hex", 0xFF, 255)
check("int bin", 0b1010, 10)
check("float literal", 3.14, 3.14)
check("float negativo", -0.5, -0.5)
check("float sci", 2.5e2, 250.0)
check("bool true", true, true)
check("bool false", false, false)
check("none", None, None)
check("str literal", "ciao", "ciao")
check("str vuota", "", "")
check("type int", type(42), "Int")
check("type float", type(3.14), "Float")
check("type bool", type(true), "Bool")
check("type str", type("x"), "Str")
check("type none", type(None), "None")
check("type array", type([1,2,3]), "Array")
check("type dict", type({}), "Dict")
check("type fn", type(fn(x) x), "Function")
check("type range", type(0..5), "Range")
section_end()

# ─────────────────────────────────────────────────────────────
# 2. OPERATORI ARITMETICI
# ─────────────────────────────────────────────────────────────
section("2. Operatori aritmetici")

check("add int", 3 + 4, 7)
check("sub int", 10 - 3, 7)
check("mul int", 3 * 4, 12)
check("div float", 7 / 2, 3.5)
check("int div", 7 // 2, 3)
check("modulo", 10 % 3, 1)
check("pow", 2 ** 10, 1024)
check("neg", -5, -5)
check("add float", 1.5 + 2.5, 4.0)
check("int+float promo", 1 + 0.5, 1.5)
check("float+int promo", 0.5 + 1, 1.5)
check("int div neg", -7 // 2, -3)  # Neba: truncation (C-style)
check("mod neg", -10 % 3, -1)  # Neba: C-style modulo
fn test_add_eq()
    var x = 5
    x += 3
    return x
fn test_sub_eq()
    var x = 5
    x -= 3
    return x
fn test_mul_eq()
    var x = 5
    x *= 3
    return x
fn test_div_eq()
    var x = 6.0
    x /= 2.0
    return x
fn test_mod_eq()
    var x = 10
    x %= 3
    return x

check("compound +=", test_add_eq(), 8)
check("compound -=", test_sub_eq(), 2)
check("compound *=", test_mul_eq(), 15)
check("compound /=", test_div_eq(), 3.0)
check("compound %=", test_mod_eq(), 1)

# IEEE 754
check("float div by zero = Inf", math.is_inf(1.0 / 0.0), true)
check("float neg div zero = -Inf", math.is_inf(-1.0 / 0.0), true)
check("float 0/0 = NaN", math.is_nan(0.0 / 0.0), true)
check("math.is_finite 1.0", math.is_finite(1.0), true)
check("math.is_finite Inf", math.is_finite(1.0 / 0.0), false)
section_end()

# ─────────────────────────────────────────────────────────────
# 3. OPERATORI DI CONFRONTO E LOGICI
