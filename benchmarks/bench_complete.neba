println("── 3. Ricorsione ────────────────────────────────────────")
# ─────────────────────────────────────────────────────

fn fib(n)
    if n <= 1
        return n
    return fib(n-1) + fib(n-2)

fn run_fib30()
    return fib(30)
fn run_fib33()
    return fib(33)
fn run_fib35()
    return fib(35)
bench_once("fib(30)",             run_fib30)
bench_once("fib(33)",             run_fib33)
bench_once("fib(35)",             run_fib35)

fn ackermann(m, n)
    if m == 0
        return n + 1
    elif n == 0
        return ackermann(m - 1, 1)
    else
        return ackermann(m - 1, ackermann(m, n - 1))
fn run_ackermann()
    return ackermann(3, 8)
bench_once("ackermann(3,8)",      run_ackermann)

fn factorial_r(n)
    if n <= 1
        return 1
    return n * factorial_r(n-1)
fn run_fact()
    var s = 0
    var i = 0
    while i < 10000
        s += factorial_r(10)
        i += 1
    return s
bench_once("factorial(10) x10K", run_fact)

