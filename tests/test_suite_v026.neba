# ─── 8. CONTROL FLOW ─────────────────────────────────
section("=== 8. CONTROL FLOW ===")
var x = 0
if true
    x = 1
check("if_t", x, 1)
if false
    x = 99
else
    x = 2
check("if_else", x, 2)
if false
    x = 0
elif true
    x = 3
else
    x = 99
check("elif", x, 3)
var cnt = 0
for i in 0..5
    cnt += 1
check("for_range5", cnt, 5)
var cnt2 = 0
for i in range(0, 10, 2)
    cnt2 += 1
check("for_step2", cnt2, 5)
var cnt3 = 0
for item in ["a","b","c","d"]
    cnt3 += 1
check("for_in", cnt3, 4)
var w = 0
var wi = 0
while wi < 10
    w += wi
    wi += 1
check("while_sum", w, 45)
var bc = 0
for i in 0..20
    if i == 7
        break
    bc += 1
check("break_at7", bc, 7)
var cc = 0
for i in 0..10
    if i % 2 == 0
        continue
    cc += 1
check("continue_odd", cc, 5)
# nested loops
var nc = 0
for i in 0..3
    for j in 0..3
        nc += 1
check("nested_loops", nc, 9)
# match expression
let mv = match 42
    0 => "zero"
    42 => "answer"
    _ => "other"
check("match_int", mv, "answer")
let ms = match "hello"
    "world" => "nope"
    "hello" => "yes"
    _ => "other"
check("match_str", ms, "yes")
let mwild = match 99
    0 => "zero"
    _ => "wild"
check("match_wild", mwild, "wild")

# ─── 9. FUNZIONI ─────────────────────────────────────
section("=== 9. FUNZIONI ===")
fn add(a, b)
    return a + b
check("fn_basic", add(3,4), 7)
fn fact(n)
    if n <= 1
        return 1
    return n * fact(n-1)
check("recursive", fact(10), 3628800)
fn fib(n)
    if n <= 1
        return n
    return fib(n-1) + fib(n-2)
check("fib_10", fib(10), 55)
fn vardef(x, y=10, z=100)
    return x + y + z
check("defaults_all", vardef(1), 111)
check("defaults_one", vardef(1, 2), 103)
check("defaults_none", vardef(1, 2, 3), 6)
fn ret_none()
    let x = 1
let fn_val = ret_none()
check("implicit_none", fn_val, None)
# first-class functions
fn apply(f, x)
    return f(x)
fn double(x)
    return x * 2
check("first_class", apply(double, 5), 10)

# ─── 10. CLOSURES ─────────────────────────────────────
section("=== 10. CLOSURES ===")
fn make_adder(n)
    fn adder(x)
        return x + n
    return adder
let add5 = make_adder(5)
let add10 = make_adder(10)
check("closure_add5", add5(3), 8)
check("closure_add10", add10(3), 13)
check("closure_independent", add5(0), 5)
fn counter()
    var n = 0
    fn inc()
        n += 1
        return n
    return inc
let inc = counter()
inc()
inc()
check("closure_state", inc(), 3)  # single closure counter

