fn math_hyperbolic()
    var s = 0.0
    for i in 1..10001
        let x = float(i) * 0.001
        s += math.sinh(x) * math.tanh(x)
    return s

fn math_misc()
    var s = 0
    for i in 0..10000
        s += math.gcd(i + 1, i + 7)
        s += math.floor(math.sqrt(float(i + 1)))
    return s

bench_once("sin/cos/sqrt/log 10K", fn() math_intensive())
